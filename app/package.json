{
  "name": "hackeros-games",
  "version": "0.6.0",
  "description": "HackerOS Games Launcher",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && mkdir -p dist/images && cp -r images/* dist/images/ && tsc -p electron/tsconfig.json",
    "start": "tsc -p electron/tsconfig.json && concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "dist": "npm run build && electron-builder --linux AppImage"
  },
  "keywords": [],
  "author": "HackerOS",
  "license": "ISC",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hackeros.games",
    "productName": "HackerOS Games",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Game",
      "icon": "images/HackerOS-Games.png"
    }
  }
}
