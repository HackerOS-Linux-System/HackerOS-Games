{
  "name": "bark-squadron",
  "version": "0.6.0",
  "description": "Bark Squadron - A 2D Dogfight Game",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage",
    "web": "vite"
  },
  "keywords": [
    "game",
    "react",
    "electron",
    "typescript"
  ],
  "author": "Bark Squadron Team",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@google/genai": "^0.2.1",
    "lucide-react": "^0.344.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.barksquadron.app",
    "productName": "Bark Squadron",
    "linux": {
      "target": "AppImage"
    }
  }
